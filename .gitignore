# Dependencies and build output
node_modules/
dist/
coverage/
.vite/
*.tsbuildinfo

# Local environment files
.env
.env.*
!.env.example

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!*.code-workspace
.clineignore

# Built Visual Studio Code Extensions
*.vsix

# Planning files intentionally local-only
PLAN.md
STYLE.md

# Sensitive KeyForge data - never commit operational data
*.sqlite
*.sqlite3
*.db
*.db3
*.mkdb
*.csv
*.tsv
*.xlsx
*.xls
*.ods
*.numbers
*.bak
*.backup
*.dump
*.sql
*.zip
*.7z
*.rar
*.tar
*.gz

# Exported sensitive reports — never commit plaintext locksmith data as PDF
*.pdf

# Cryptographic key material — never commit private keys or certificates
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt

# Log files
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Test output (Playwright, deferred but pre-blocked)
test-results/
playwright-report/
blob-report/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
